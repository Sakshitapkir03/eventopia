# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/eventopia

# Uploadthing (Image Uploads)
UPLOADTHING_TOKEN=your_uploadthing_token

# Stripe Payments
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Resend (Email)
RESEND_API_KEY=your_resend_api_key

# App
NEXT_PUBLIC_SERVER_URL=https://your-domain.vercel.app

# Admin — comma-separated Clerk user IDs that have admin access
ADMIN_USER_IDS=user_your_clerk_id_here

# Cron — secret to protect /api/cron/reminders
CRON_SECRET=change_this_to_a_strong_random_secret
